generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  password     String?
  googleId     String?  @unique
  createdAt    DateTime @default(now())
  shadowScore  Int      @default(0)
  isBanned     Boolean  @default(false)
  bio          String?
  profilePhoto String?
  role         Role     @default(USER)

  participations   ThreadParticipant[]
  submittedThreads Thread[]
  votes            Vote[]
  threadLikes      ThreadLike[]
  notifications    Notification[]
  reportsMade      Report[]            @relation("ReportsMade")
  reportsReceived  Report[]            @relation("ReportsReceived")

  @@map("users")
}

model Thread {
  id          String   @id @default(uuid())
  url         String?
  domain      String?
  title       String
  description String?
  imageUrl    String?
  isAnonymous Boolean  @default(false)
  createdAt   DateTime @default(now())

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  comments     Comment[]
  participants ThreadParticipant[]
  likes        ThreadLike[]
  reports      Report[]

  @@index([domain])
  @@map("threads")
}

model ThreadParticipant {
  id          String   @id @default(uuid())
  userId      String
  threadId    String
  pseudonym   String
  avatarColor String
  isAnonymous Boolean
  joinedAt    DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread   Thread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  comments Comment[]

  @@unique([userId, threadId])
  @@map("thread_participants")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  createdAt DateTime @default(now())
  upvotes   Int      @default(0)
  downvotes Int      @default(0)

  participantId String
  threadId      String
  parentId      String?

  participant ThreadParticipant @relation(fields: [participantId], references: [id])
  thread      Thread            @relation(fields: [threadId], references: [id], onDelete: Cascade)
  parent      Comment?          @relation("CommentReplies", fields: [parentId], references: [id])
  replies     Comment[]         @relation("CommentReplies")
  votes       Vote[]
  reports     Report[]

  @@map("comments")
}

model Vote {
  id        String   @id @default(uuid())
  type      String
  createdAt DateTime @default(now())

  userId    String
  commentId String

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@map("votes")
}

model ThreadLike {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())

  userId   String
  threadId String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@map("thread_likes")
}

model WhitelistDomain {
  id         String   @id @default(uuid())
  domain     String   @unique
  trustScore Int      @default(100)
  addedAt    DateTime @default(now())

  @@map("whitelist_domains")
}

model Notification {
  id        String   @id @default(uuid())
  type      String // "COMMENT_ON_THREAD" | "REPLY_TO_COMMENT"
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  // The user who should receive this notification
  recipientId String
  recipient   User   @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  // Context fields for rendering the notification
  threadId       String
  threadTitle    String
  commentId      String
  actorPseudonym String // pseudonym of who triggered it

  @@index([recipientId, isRead])
  @@map("notifications")
}

model Report {
  id             String    @id @default(uuid())
  reason         String
  createdAt      DateTime  @default(now())
  resolved       Boolean   @default(false)
  resolvedAt     DateTime?
  action         String?   // "DISMISSED" | "CONTENT_DELETED" | "USER_BANNED"
  resolvedById   String?

  reporterId     String
  reporter       User    @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)

  reportedUserId String
  reportedUser   User    @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)

  threadId  String?
  thread    Thread?  @relation(fields: [threadId], references: [id], onDelete: Cascade)

  commentId String?
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([resolved])
  @@index([reportedUserId])
  @@map("reports")
}
